@{
    ViewData["Title"] = "Home Page";
}

<!-- Premium Café Palette: Cream, Ivory, Deep Brown & Sage Green Accents -->
<style>
    body {
        background-color: #fbf9f4 !important; /* Premium Warm Ivory Background */
    }

    .text-cafe-dark {
        color: #3d2a1d; /* Rich Dark Espresso Brown */
    }

    .text-cafe-muted {
        color: #705c4e; /* Warm Soft Roasted Brown */
    }

    .bg-sage-badge {
        background-color: #dbe4da; /* Elegant Soft Sage from your reference */
        color: #2f4034;
    }

    .bg-ivory-card {
        background-color: #f7f4ed; /* Smooth Ivory surface for cards */
        border: 1px solid #ede9df;
    }

    .bg-sage-banner {
        background-color: #dce3db; /* Muted Sage background panel */
    }

    .btn-cafe-brown {
        background-color: #523b2b; /* Sophisticated Café Deep Brown Accent */
        color: #fbf9f4;
        border: none;
        transition: all 0.2s ease;
    }

        .btn-cafe-brown:hover {
            background-color: #3d2a1d;
            color: #fbf9f4;
        }

    .btn-outline-cafe {
        border: 2px solid #523b2b;
        color: #523b2b;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-outline-cafe:hover {
            background-color: #523b2b;
            color: #fbf9f4;
        }

    .menu-pill-btn {
        background-color: #eeeae1;
        color: #523b2b;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

        .menu-pill-btn:hover, .menu-pill-btn.active {
            background-color: #523b2b;
            color: #fbf9f4;
        }

    .hero-frame {
        border-radius: 24px; /* Clean, structured rounded rectangle matching IMG_6358 */
        object-fit: cover;
        height: 480px;
        width: 100%;
    }
</style>

<!-- SECTION 1: CLEAN STRUCTURED HERO (Inspired by IMG_6358 / IMG_6359 Layouts) -->
<div class="container my-5 py-3">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <span class="badge px-3 py-2 rounded-pill bg-sage-badge fw-bold mb-3">🌿 Specialty Coffee House</span>
            <h1 class="display-4 fw-bold text-cafe-dark mb-3 lh-sm">Brewed Fresh,<br>Served Warm</h1>
            <p class="fs-5 text-cafe-muted mb-4">Experience a cozy aesthetic atmosphere, fresh signature pastries, and premium handcrafted roasts in the heart of the city.</p>

            <div class="d-flex gap-3 align-items-center">
                <a asp-controller="Home" asp-action="Menu" class="btn btn-cafe-brown btn-lg px-4 py-3 rounded-pill fw-bold shadow-sm">Explore Menu</a>
                <a asp-controller="Home" asp-action="Booking" class="btn btn-outline-cafe btn-lg px-4 py-3 rounded-pill">Book a Table</a>
            </div>

            <!-- Minimal Info Row from Reference 0027A47D -->
            <div class="d-flex gap-4 mt-5 text-cafe-muted border-top pt-4">
                <div>✨ <span class="small ms-1 fw-bold">100% Arabica Beans</span></div>
                <div>🤎 <span class="small ms-1 fw-bold">Crafted with Care</span></div>
                <div>☕ <span class="small ms-1 fw-bold">Aesthetic Space</span></div>
            </div>
        </div>

        <div class="col-lg-6">
            <!-- Clean, structured rectangle photo layout matching your references -->
            <img src="https://images.unsplash.com/photo-1609590981063-d495e2914ce4?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MzA2fHxjYWZlfGVufDB8fDB8fHww" class="hero-frame shadow-sm" alt="Café Specialty Setup" />
        </div>
    </div>
</div>

<!-- SECTION 2: VALUES STRIP (Inspired by 0027A47D-8A2D-4C58-BD3F-D3D26DBCBAA8.jpg) -->
<div class="bg-sage-banner py-4 my-5 rounded-4 container shadow-inner">
    <div class="row text-center g-3">
        <div class="col-md-3 border-end border-white border-opacity-20">
            <h6 class="fw-bold text-cafe-dark mb-1">Selected Beans</h6>
            <p class="small text-cafe-muted mb-0">Directly sourced single origins</p>
        </div>
        <div class="col-md-3 border-end border-white border-opacity-20">
            <h6 class="fw-bold text-cafe-dark mb-1">Fresh Roasting</h6>
            <p class="small text-cafe-muted mb-0">Small batches micro-roasted</p>
        </div>
        <div class="col-md-3 border-end border-white border-opacity-20">
            <h6 class="fw-bold text-cafe-dark mb-1">Expert Baristas</h6>
            <p class="small text-cafe-muted mb-0">Brewed with absolute precision</p>
        </div>
        <div class="col-md-3">
            <h6 class="fw-bold text-cafe-dark mb-1">Cozy Space</h6>
            <p class="small text-cafe-muted mb-0">Your peaceful morning escape</p>
        </div>
    </div>
</div>

<!-- SECTION 3: POPULAR ITEMS (Ivory Cards & Deep Brown Plus Sign Buttons) -->
<div class="container my-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold text-cafe-dark mb-0">Popular Drinks</h2>
            <p class="text-cafe-muted mb-0">Our community favorites, prepared to absolute perfection.</p>
        </div>
        <a asp-controller="Home" asp-action="Menu" class="btn btn-outline-cafe btn-sm rounded-pill px-3">View Full Menu</a>
    </div>

    <!-- Categories Selector Filter Row from IMG_6358 -->
    <div class="d-flex gap-2 mb-4 overflow-auto pb-2">
        <button class="btn menu-pill-btn active px-4 py-2">Iced Coffee</button>
        <button class="btn menu-pill-btn px-4 py-2">Milk-Based Coffee</button>
        <button class="btn menu-pill-btn px-4 py-2">Classic Brews</button>
        <button class="btn menu-pill-btn px-4 py-2">Sweet Treats</button>
    </div>

    <!-- Product Display Grid -->
    <div class="row g-4">
        <!-- Item 1: Signature Latte -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-ivory-card text-center h-100">
                <img src="https://media.istockphoto.com/id/2243222953/photo/refreshing-iced-matcha-drink-modern-healthy-lifestyle-concept.jpg?s=612x612&w=0&k=20&c=TFy06pRYdV804fUAITI1ixS2oHblM6IJiWTtqw-bzl4=" class="rounded-3 mb-3" style="height: 230px; object-fit: cover; width: 100%;" alt="Signature Latte" />
                <h5 class="fw-bold text-cafe-dark mb-1">Signature Latte</h5>
                <p class="text-cafe-muted small mb-3">Creamy, velvety steamed milk poured expertly over rich espresso.</p>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                    <span class="fw-bold text-cafe-dark fs-5">$4.50</span>
                    <button class="btn btn-cafe-brown rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 36px; height: 36px; padding: 0;">+</button>
                </div>
            </div>
        </div>

        <!-- Item 2: Ceremonial Matcha -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-ivory-card text-center h-100">
                <img src="https://media.istockphoto.com/id/846454458/photo/food-photos.jpg?s=612x612&w=0&k=20&c=poS33LKALem6nThi_BfrdzFWzOtCvcucy39BBudWQVE=" class="rounded-3 mb-3" style="height: 230px; object-fit: cover; width: 100%;" alt="Ceremonial Matcha" />
                <h5 class="fw-bold text-cafe-dark mb-1">Ceremonial Matcha</h5>
                <p class="text-cafe-muted small mb-3">Authentic stone-ground Japanese green tea whisked into velvet perfection.</p>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                    <span class="fw-bold text-cafe-dark fs-5">$4.80</span>
                    <button class="btn btn-cafe-brown rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 36px; height: 36px; padding: 0;">+</button>
                </div>
            </div>
        </div>

        <!-- Item 3: Cold Brew Filter -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-ivory-card text-center h-100">
                <img src="https://images.unsplash.com/photo-1517701604599-bb29b565090c?q=80&w=400" class="rounded-3 mb-3" style="height: 230px; object-fit: cover; width: 100%;" alt="Cold Brew Filter" />
                <h5 class="fw-bold text-cafe-dark mb-1">Cold Brew Filter</h5>
                <p class="text-cafe-muted small mb-3">Slow-extracted over 18 hours for an incredibly clean, crisp profile.</p>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                    <span class="fw-bold text-cafe-dark fs-5">$4.20</span>
                    <button class="btn btn-cafe-brown rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 36px; height: 36px; padding: 0;">+</button>
                </div>
            </div>
        </div>
    </div>
</div>